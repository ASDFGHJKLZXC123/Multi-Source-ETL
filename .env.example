# =============================================================================
# Multi-Source ETL Pipeline — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit .env to git — it is in .gitignore.
# =============================================================================

# ── PostgreSQL (Stage 0 — Docker) ────────────────────────────────────────────
# LOCAL DEVELOPMENT: DB_HOST=localhost  (Python runs on your machine, Postgres in Docker)
# CONTAINERISED RUN: DB_HOST is overridden to etl-postgres by docker-compose.yml
#                    via the environment: block — no manual change needed.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=etl_pipeline
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ── Kaggle API (Stage 1 — Olist dataset download) ────────────────────────────
# Sign up free at https://www.kaggle.com
# Go to: Account Settings → API → Create New Token
# This downloads kaggle.json — place it at ~/.kaggle/kaggle.json (chmod 600)
# OR set the two variables below directly:
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Weather API (Stage 1/2 — historical weather by city) ─────────────────────
# PRIMARY: Open-Meteo (recommended — free, no key, ERA5 data back to 1940)
# Base URL: https://archive-api.open-meteo.com/v1/archive
# No credentials required — leave the WEATHER_PROVIDER setting below.
WEATHER_PROVIDER=open-meteo

# ALTERNATIVE: OpenWeatherMap (requires free API key, limited history on free tier)
# Sign up: https://openweathermap.org/api
# Free tier: current weather + 5-day forecast only (historical requires paid plan)
# WEATHER_PROVIDER=openweathermap
# OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# ── FX Rate API (Stage 1/2 — historical exchange rates) ──────────────────────
# PRIMARY: Frankfurter (recommended — free, no key, ECB data back to 1999)
# Base URL: https://api.frankfurter.dev/v2
# No credentials required — leave the FX_PROVIDER setting below.
FX_PROVIDER=frankfurter

# ALTERNATIVE: Exchangerate.host (requires free API key)
# Sign up: https://exchangerate.host (free tier available)
# EXCHANGERATEHOST_API_KEY=your_exchangeratehost_api_key_here
# FX_PROVIDER=exchangeratehost

# ── Pipeline Configuration ────────────────────────────────────────────────────
# Date window covered by the Olist dataset
PIPELINE_START_DATE=2016-09-01
PIPELINE_END_DATE=2018-10-31

# Top N cities by order volume to fetch weather for
WEATHER_CITY_COUNT=20

# Base currency for FX conversion
FX_BASE_CURRENCY=USD
FX_QUOTE_CURRENCY=BRL

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
