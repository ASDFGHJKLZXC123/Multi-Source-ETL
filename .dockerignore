# =============================================================================
# .dockerignore — Multi-Source ETL Pipeline
# =============================================================================
# Excludes files from the Docker build context.
# Keeping the context small speeds up the image build and prevents secrets
# or large data files from being baked into layers.
# =============================================================================

# ---------------------------------------------------------------------------
# Secrets — never bake credentials into the image
# ---------------------------------------------------------------------------
.env
.env.*
*.env
**/.kaggle/

# ---------------------------------------------------------------------------
# Runtime-generated data — arrives via bind mount at run time
# ---------------------------------------------------------------------------
data/bronze/
data/silver/
data/gold/

# ---------------------------------------------------------------------------
# Log files — also arrive via bind mount
# ---------------------------------------------------------------------------
logs/

# ---------------------------------------------------------------------------
# Python bytecode and caches
# ---------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/

# ---------------------------------------------------------------------------
# Development and test fixtures — not needed at runtime
# ---------------------------------------------------------------------------
tests/
notebooks/
scripts/

# ---------------------------------------------------------------------------
# Documentation and reporting artefacts
# ---------------------------------------------------------------------------
docs/
pbix/

# ---------------------------------------------------------------------------
# IDE and OS metadata
# ---------------------------------------------------------------------------
.git/
.gitignore
.gitattributes
.DS_Store
Thumbs.db
.idea/
.vscode/

# ---------------------------------------------------------------------------
# CI / tooling configs
# ---------------------------------------------------------------------------
Makefile
pyproject.toml
requirements-dev.txt
.github/
